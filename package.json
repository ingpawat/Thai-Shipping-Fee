{
  "name": "thai-shipping-fee",
  "version": "1.0.1",
  "description": "Calculate shipping costs in Thailand based location",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
